file_mounts:
  /mount_private:
    name: {{storage_name}}
    source: ~/tmp-workdir
    mode: MOUNT
    mount_options: '{{mount_options}}'

run: |
  set -ex
  # Verify the mount is readable and files from source were uploaded
  ls /mount_private/foo
  ls /mount_private/tmp\ file
  # Verify that --read-only actually prevents writes
  if echo "test" > /mount_private/write_test.txt 2>/dev/null; then
    echo "ERROR: Write succeeded on read-only mount"
    exit 1
  fi
  echo "Write correctly denied on read-only mount."
  # Verify that block-cache is active by checking blobfuse2 process flags
  if ps aux | grep -v grep | grep blobfuse2 | grep -q block-cache; then
    echo "SUCCESS: blobfuse2 running with block-cache enabled"
  else
    echo "ERROR: blobfuse2 not running with block-cache flags"
    ps aux | grep blobfuse2
    exit 1
  fi
